# ============================================================
# Python / Django
# ============================================================

# Virtual environments
venv/
.venv/
env/
.env/

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
sdist/

# Django migrations (each dev regenerates from models)
*/migrations/*.py
!*/migrations/__init__.py

# Database files
db.sqlite3
db.sqlite3-journal
*.db

# Environment variables / secrets
.env
.env.*

# Django static files (collected)
staticfiles/
static_collected/

# Media uploads (user-generated content)
media/

# ============================================================
# Node.js / React (frontend/)
# ============================================================

# Dependencies
frontend/node_modules/
node_modules/

# Build output
frontend/dist/
frontend/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

